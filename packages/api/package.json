{
  "name": "@mcp-coord/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "test": "jest --runInBand --config ./jest.config.js",
    "migration:run": "pnpm build && pnpm exec typeorm migration:run -d dist/database/coord-data-source.js",
    "migration:revert": "pnpm build && pnpm exec typeorm migration:revert -d dist/database/coord-data-source.js",
    "migration:show": "pnpm build && pnpm exec typeorm migration:show -d dist/database/coord-data-source.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/typeorm": "^10.0.2",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.27"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.22",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.57",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "testcontainers": "^11.14.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.4.5"
  }
}
